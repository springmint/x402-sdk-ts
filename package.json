{
  "name": "@springmint/x402",
  "version": "0.1.1",
  "description": "x402 TypeScript SDK (TRON and EVM support)",
  "keywords": [
    "x402",
    "tron",
    "trx",
    "ethereum",
    "evm",
    "payment",
    "blockchain"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "tronweb": "^5.0.0 || ^6.0.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv": "^16.4.5",
    "tronweb": "^6.2.1",
    "typescript": "^5.3.0",
    "viem": "^2.46.3",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "packageManager": "yarn@4.12.0"
}
